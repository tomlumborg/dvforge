{
  "name": "dvforge",
  "version": "0.1.1",
  "description": "Compile compact YAML into a Dataverse solution tree",
  "bin": {
    "dvforge": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomlumborg/dvforge.git"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tomlumborg/dvforge"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format cjs --out-dir dist",
    "postbuild": "chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5",
    "commander": "^12",
    "uuid": "^10",
    "yaml": "^2",
    "zod": "^3",
    "zod-to-json-schema": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/uuid": "^10",
    "tsup": "^8",
    "typescript": "^5"
  }
}
