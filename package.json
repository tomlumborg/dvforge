{
  "name": "dvforge",
  "version": "0.1.1",
  "description": "YAML → pac-ready Dataverse table solutions.",
  "license": "SEE LICENSE IN LICENSE.md",
  "keywords": ["dataverse", "dv", "powerapps"],
  "bin": {
    "dvforge": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "postbuild": "chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5",
    "commander": "^12",
    "uuid": "^10",
    "yaml": "^2",
    "zod": "^3",
    "zod-to-json-schema": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/uuid": "^10",
    "tsup": "^8",
    "typescript": "^5"
  }
}
