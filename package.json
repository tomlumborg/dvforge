{
  "name": "dvforge",
  "version": "0.1.1",
  "description": "YAML → pac-ready Dataverse table solutions.",
  "license": "SEE LICENSE IN LICENSE.md",
  "keywords": [
    "dataverse",
    "dv",
    "powerapps"
  ],
  "bin": {
    "dvforge": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"import('fs').then(fs=>fs.chmodSync('dist/cli.js',0o755))\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "chalk": "^5",
    "commander": "^12",
    "uuid": "^14.0.0",
    "yaml": "^2",
    "zod": "^3",
    "zod-to-json-schema": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
