        }
      },
      "required": [
        "related_table",
        "lookup_column"
      ],
      "title": "Relationship",
      "type": "object"
    }
  },
  "properties": {
    "entities": {
      "items": {
        "$ref": "#/$defs/Entity"
      },
      "title": "Entities",
      "type": "array"
    }
